{
  "name": "@gonzih/mcp-google-calendar-sa",
  "version": "0.1.0",
  "description": "MCP server for Google Calendar using a service account JSON key",
  "main": "dist/index.js",
  "bin": {
    "mcp-google-calendar-sa": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "files": ["dist", "src"],
  "keywords": ["mcp", "google-calendar", "service-account"],
  "author": "gonzih",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "googleapis": "173.0.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "22.15.21",
    "jest": "29.7.0",
    "ts-jest": "29.3.4",
    "typescript": "5.8.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"]
  }
}
